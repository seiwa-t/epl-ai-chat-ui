# EPL AI Chat UI Configuration
# 初回起動時に config.yaml として自動コピーされます。
# APIキーを設定してください。

engine:
  # active: claude | openai | gemini
  active: claude

  claude:
    api_key: ""
    model: "claude-sonnet-4-6"

  openai:
    api_key: ""
    model: "gpt-4o"

  gemini:
    api_key: ""
    model: "gemini-2.5-flash"

epl:
  core_path: "data/epl_cores/first_epero_core_v1.5.epl"

memory:
  db_path: "data/db/epel.db"
  instant_memory_max_tokens: 2000
  novelty_decay_rate: 0.95
  trash_retention_days: 15

server:
  host: "0.0.0.0"
  port: 8000

# ========== 認証設定 ==========
auth:
  # false = ローカル開発モード（ログイン不要）
  # true  = Google SSOを有効化
  enabled: false

  google_client_id: ""
  google_client_secret: ""
  base_url: "http://localhost:8000"

  # JWT署名キー（python -c "import secrets; print(secrets.token_hex(32))" で生成）
  jwt_secret: ""

  # 招待するGmailアドレスのリスト（空の場合は全員許可）
  allowed_emails: []
  #  - "example@gmail.com"
